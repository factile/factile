{
  "id": "software.answer-question",
  "title": "Answer Question",
  "profile": "software",
  "mode": "reader",
  "purpose": "Answer an engineering question using local knowledge before relying on memory.",
  "steps": [
    {
      "title": "Discover relevant scopes",
      "command": "factile list / --brief --json"
