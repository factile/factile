{
  "id": "software.design-feature",
  "title": "Design Feature",
  "profile": "software",
  "mode": "curator",
  "purpose": "Prepare a feature design using existing local knowledge and profile templates.",
  "steps": [
    {
      "title": "Inspect the target scope",
      "command": "factile list <scope> --brief --json"
    },
    {
      "title": "Gather design context",
      "command": "factile context <scope> <feature summary> --json"
    },
    {
      "title": "Create or update design document",
      "command": "factile create <path> --type \"Technical Design\" --title <title> --body <file>"
    },
    {
      "title": "Validate the target scope",
      "command": "factile validate <scope> --json"
    }
  ]
}
